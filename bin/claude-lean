#!/usr/bin/env bash
# Lean Claude Code launcher (OAuth-safe).
# Reads optional ~/.claude/claude-lean.conf for custom tool lists.

set -euo pipefail

expand_home() {
  local path="$1"
  case "$path" in
    "~") printf '%s' "$HOME" ;;
    "~/"*) printf '%s/%s' "$HOME" "${path:2}" ;;
    *) printf '%s' "$path" ;;
  esac
}

PROMPT_FILE="$(expand_home "${CLAUDE_LEAN_PROMPT_FILE:-$HOME/.claude/system-prompt-lean.txt}")"
CONF_FILE="$(expand_home "${CLAUDE_LEAN_CONF:-$HOME/.claude/claude-lean.conf}")"

TOOLS="Bash,Edit,Read,Write,WebFetch,WebSearch"
EFFORT="medium"
DISALLOWED="mcp__*"

if [[ -f "$CONF_FILE" ]]; then
  # shellcheck disable=SC1090
  source "$CONF_FILE"
fi

if [[ ! -f "$PROMPT_FILE" ]]; then
  echo "claude-lean: missing system prompt file: $PROMPT_FILE" >&2
  echo "Run the installer: curl -fsSL https://raw.githubusercontent.com/0p9b/claude-code-lean/main/install.sh | bash" >&2
  exit 1
fi

if ! command -v claude >/dev/null 2>&1; then
  echo "claude-lean: 'claude' not found on PATH. Install Claude Code CLI first." >&2
  exit 1
fi

args=(
  --system-prompt-file "$PROMPT_FILE"
  --tools "$TOOLS"
  --effort "$EFFORT"
)

if [[ -n "$DISALLOWED" ]]; then
  args+=(--disallowedTools "$DISALLOWED")
fi

exec claude "${args[@]}" "$@"
