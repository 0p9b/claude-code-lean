#!/usr/bin/env bash
# Lean Claude Code launcher (OAuth-safe).
# Same settings as regular `claude`, but replaces the product system prompt.
#
# Enabled tools: Bash, Read, Write, Edit, WebSearch, WebFetch
# Effort: medium
#
# Usage:
#   claude-lean
#   claude-lean -p "hi"
#   CLAUDE_LEAN_PROMPT_FILE=~/my.txt claude-lean

set -euo pipefail

PROMPT_FILE="${CLAUDE_LEAN_PROMPT_FILE:-$HOME/.claude/system-prompt-lean.txt}"

if [[ ! -f "$PROMPT_FILE" ]]; then
  echo "claude-lean: missing system prompt file: $PROMPT_FILE" >&2
  echo "Run ./install.sh from this repo first." >&2
  exit 1
fi

if ! command -v claude >/dev/null 2>&1; then
  echo "claude-lean: 'claude' not found on PATH. Install Claude Code CLI first." >&2
  exit 1
fi

# Keep OAuth. Do not pass --bare (that requires ANTHROPIC_API_KEY).
exec claude \
  --system-prompt-file "$PROMPT_FILE" \
  --tools "Bash,Edit,Read,Write,WebFetch,WebSearch" \
  --disallowedTools "mcp__*" \
  --effort medium \
  "$@"
